{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Plant": {
      "title": "Plant",
      "description": "A plant in a user's collection.",
      "type": "object",
      "properties": {
        "commonName": { "type": "string" },
        "scientificName": { "type": "string" },
        "family": { "type": "string" },
        "nickname": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "sunlight": { "type": "string" },
        "wateringFrequency": { "type": "string" },
        "soilType": { "type": "string" },
        "difficulty": { "type": "string" },
        "toxicity": {
          "type": "object",
          "properties": {
            "pets": { "type": "boolean" },
            "children": { "type": "boolean" },
            "details": { "type": "string" }
          }
        },
        "careInstructions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "funFact": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "lastWatered": { "type": "string", "format": "date-time" },
        "wateringLog": {
          "type": "array",
          "items": { "type": "string", "format": "date-time" }
        },
        "notes": { "type": "string" }
      },
      "required": ["commonName", "scientificName", "photoURL", "nickname"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/plants/{plantId}": {
      "schema": "Plant",
      "description": "A plant in the user's collection."
    }
  }
}
